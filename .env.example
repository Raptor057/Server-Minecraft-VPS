# Copia este archivo a `.env` y ajusta los valores a tu entorno.

COMPOSE_PROJECT_NAME=minecraft-bedrock
CONTAINER_NAME=minecraft_bedrock_server

MINECRAFT_IMAGE=itzg/minecraft-bedrock-server
MINECRAFT_TAG=latest

BEDROCK_PORT=19132
DATA_PATH=./bedrock-data

EULA=TRUE
VERSION=LATEST
SERVER_NAME=Raptor Bedrock
GAMEMODE=survival
DIFFICULTY=normal
MAX_PLAYERS=25
ONLINE_MODE=true

LEVEL_NAME=raptor
LEVEL_SEED=
LEVEL_TYPE=DEFAULT

VIEW_DISTANCE=12
TICK_DISTANCE=4
MAX_THREADS=2
PLAYER_IDLE_TIMEOUT=30

ALLOW_CHEATS=false
WHITE_LIST=false
WHITE_LIST_USERS=
OPS=

PACKAGE_BACKUP_KEEP=2

STOP_GRACE_PERIOD=60s
MEMORY_LIMIT=2800m

HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=5
HEALTHCHECK_START_PERIOD=60s

LOG_MAX_SIZE=10m
LOG_MAX_FILE=5
