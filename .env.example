# Copia este archivo a `.env` y ajusta los valores a tu entorno.

COMPOSE_PROJECT_NAME=minecraft-crafty
CRAFTY_CONTAINER_NAME=crafty_container

CRAFTY_IMAGE=registry.gitlab.com/crafty-controller/crafty-4
CRAFTY_TAG=latest

TZ=America/Chicago

CRAFTY_PANEL_PORT=8443
CRAFTY_DYNMAP_PORT=8123
CRAFTY_BEDROCK_PORT=19132
CRAFTY_JAVA_PORT_RANGE=25500-25600

CRAFTY_BACKUPS_PATH=./crafty/backups
CRAFTY_LOGS_PATH=./crafty/logs
CRAFTY_SERVERS_PATH=./crafty/servers
CRAFTY_CONFIG_PATH=./crafty/config
CRAFTY_IMPORT_PATH=./crafty/import
